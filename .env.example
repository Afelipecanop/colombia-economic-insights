# ============================================================
# Colombia Economic Insights - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ------------------------------------------------------------
# Google Cloud Platform
# ------------------------------------------------------------

# GCP project ID where your BigQuery datasets are hosted
GCP_PROJECT_ID=analisis-finanzas-globales

# Path to your Google Cloud service account key (JSON)
# Used for BigQuery queries and Looker Studio uploads
# Obtain it from: GCP Console > IAM & Admin > Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=service-account-key.json

# ------------------------------------------------------------
# BigQuery
# ------------------------------------------------------------

# Optional prefix to filter datasets by name
BQ_DATASET_PREFIX=colombia_

# ------------------------------------------------------------
# Authentication - Service Account
# ------------------------------------------------------------
# Place the downloaded JSON key at the path set in GOOGLE_APPLICATION_CREDENTIALS.
# Required roles:
#   - BigQuery Data Viewer
#   - BigQuery Job User
#   - Drive File (only needed for --looker uploads)
